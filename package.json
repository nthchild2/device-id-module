{
  "name": "fintech-security",
  "version": "0.1.0",
  "description": "Expo native module that returns a unique device identifier (FintechSecurity)",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "jest",
    "test:example": "cd example && CI=1 npx jest",
    "test:android": "cd example/android && ./gradlew :fintech-security:testDebugUnitTest --rerun",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "fintech-security",
    "FintechSecurity"
  ],
  "repository": "https://github.com/nthchild2/fintech-security",
  "bugs": {
    "url": "https://github.com/nthchild2/fintech-security/issues"
  },
  "author": "nthchild1 <nthchild1@gmail.com> (https://github.com/nthchild2)",
  "license": "MIT",
  "homepage": "https://github.com/nthchild2/fintech-security#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~57.0.0",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^57.0.2",
    "expo-modules-core": "~3.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "prettier": "^3.0.0",
    "react": "^19.2.3",
    "react-native": "^0.86.0",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
